NODE_ENV=development
PORT=4000
APP_ORIGIN=https://app.portfoli.app
RENDER_ORIGIN_SUFFIX=.portfoli.app

DATABASE_URL=postgresql://portfoli:portfoli@localhost:5432/portfoli
REDIS_URL=redis://localhost:6379

# RS256 JWT keys (PEM). Generate with:
#   openssl genpkey -algorithm RSA -out keys/jwt.key -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in keys/jwt.key -pubout -out keys/jwt.pub
JWT_PRIVATE_KEY_PATH=./keys/jwt.key
JWT_PUBLIC_KEY_PATH=./keys/jwt.pub
JWT_ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000

# Cloudflare R2 (S3-compatible). Region must be 'auto'.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfoli-assets
R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_BASE_URL=https://cdn.portfoli.app
R2_PRESIGN_TTL_SEC=300

RESEND_API_KEY=
MAIL_FROM="Portfoli <noreply@portfoli.app>"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

HCAPTCHA_SECRET=
SENTRY_DSN=

SESSION_SALT=change-me-in-prod
ANALYTICS_SALT_ROTATION_CRON=0 0 * * *
